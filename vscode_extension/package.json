{
  "name": "prism-risk-gate",
  "displayName": "PRism - Deployment Risk Intelligence",
  "description": "AI-powered pre-deployment risk gate. Shows a Deployment Confidence Score, risk findings, and rollback playbooks right in your VS Code sidebar.",
  "version": "0.1.3",
  "publisher": "thegooddatalab",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soni-ishan/PRism.git"
  },
  "categories": [
    "Other",
    "Testing"
  ],
  "icon": "media/prism-icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prism-container",
          "title": "PRism",
          "icon": "media/prism-icon.svg"
        }
      ]
    },
    "views": {
      "prism-container": [
        {
          "type": "webview",
          "id": "prism.sidebar",
          "name": "Deployment Confidence",
          "icon": "media/prism-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "prism.rerunAnalysis",
        "title": "PRism: Re-run Analysis",
        "icon": "$(refresh)"
      },
      {
        "command": "prism.showReport",
        "title": "PRism: Show Full Report"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "prism.rerunAnalysis",
          "when": "view == prism.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "PRism",
      "properties": {
        "prism.serverUrl": {
          "type": "string",
          "default": "https://prism-dev-orchestrator.politerock-2dda79e7.eastus2.azurecontainerapps.io",
          "description": "URL of the PRism FastAPI backend server.  Defaults to the hosted PRism instance — no setup needed."
        },
        "prism.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically poll and refresh the sidebar at a fixed interval."
        },
        "prism.refreshIntervalSeconds": {
          "type": "number",
          "default": 30,
          "description": "Polling interval (in seconds) for auto-refresh."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npx --no-install tsc -p ./",
    "watch": "npx --no-install tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.56.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {}
}
