{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "projectName": {
      "value": "prism"
    },
    "environment": {
      "value": "prod"
    },
    "location": {
      "value": "eastus2"
    },
    "githubToken": {
      "value": "YOUR_GITHUB_TOKEN_HERE"
    },
    "githubWebhookSecret": {
      "value": "YOUR_WEBHOOK_SECRET_HERE"
    },
    "githubRepoOwner": {
      "value": "your-github-org"
    },
    "githubRepoName": {
      "value": "your-repo-name"
    },
    "openAiModelDeployment": {
      "value": "gpt-4o"
    },
    "openAiModelVersion": {
      "value": "2024-11-20"
    },
    "openAiModelCapacity": {
      "value": 30
    },
    "tags": {
      "value": {
        "project": "PRism",
        "environment": "prod",
        "managedBy": "Bicep",
        "owner": "your-team"
      }
    }
  }
}
