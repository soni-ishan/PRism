{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "17149638020305858309"
    }
  },
  "parameters": {
    "projectName": {
      "type": "string",
      "defaultValue": "prism",
      "minLength": 3,
      "maxLength": 10,
      "metadata": {
        "description": "Project name prefix for all resources"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "prod",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Environment name (dev, staging, prod)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resource deployment"
      }
    },
    "githubToken": {
      "type": "securestring",
      "metadata": {
        "description": "GitHub Personal Access Token"
      }
    },
    "githubWebhookSecret": {
      "type": "securestring",
      "metadata": {
        "description": "GitHub Webhook Secret"
      }
    },
    "githubRepoOwner": {
      "type": "string",
      "metadata": {
        "description": "GitHub repository owner/organization"
      }
    },
    "githubRepoName": {
      "type": "string",
      "metadata": {
        "description": "GitHub repository name"
      }
    },
    "openAiModelDeployment": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "Azure OpenAI model deployment name"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "PRism",
        "environment": "[parameters('environment')]",
        "managedBy": "Bicep"
      },
      "metadata": {
        "description": "Tags to apply to all resources"
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "namingPrefix": "[format('{0}-{1}', parameters('projectName'), parameters('environment'))]",
    "containerRegistryName": "[format('{0}acr{1}', parameters('projectName'), variables('uniqueSuffix'))]",
    "openAiName": "[format('{0}-openai', variables('namingPrefix'))]",
    "searchName": "[format('{0}-search-{1}', variables('namingPrefix'), variables('uniqueSuffix'))]",
    "contentSafetyName": "[format('{0}-contentsafety', variables('namingPrefix'))]",
    "appInsightsName": "[format('{0}-appins', variables('namingPrefix'))]",
    "keyVaultName": "[format('{0}-kv-{1}', parameters('projectName'), variables('uniqueSuffix'))]",
    "containerAppEnvName": "[format('{0}-env', variables('namingPrefix'))]",
    "containerAppName": "[format('{0}-orchestrator', variables('namingPrefix'))]",
    "orchestratorIdentityName": "[format('{0}-orchestrator-identity', variables('namingPrefix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[variables('containerAppName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('orchestratorIdentityName')))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2023-07-01').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('orchestratorIdentityName'))]"
            }
          ],
          "secrets": [
            {
              "name": "appinsights-connection-string",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "github-token",
              "value": "[parameters('githubToken')]"
            },
            {
              "name": "github-webhook-secret",
              "value": "[parameters('githubWebhookSecret')]"
            },
            {
              "name": "openai-api-key",
              "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('openAiName')), '2023-05-01').key1]"
            },
            {
              "name": "content-safety-key",
              "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('contentSafetyName')), '2023-05-01').key1]"
            },
            {
              "name": "search-admin-key",
              "value": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('searchName')), '2023-11-01').primaryKey]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "orchestrator",
              "image": "[format('{0}/prism-orchestrator:latest', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('containerRegistryName')), '2023-07-01').loginServer)]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "AZURE_OPENAI_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('openAiName')), '2023-05-01').endpoint]"
                },
                {
                  "name": "AZURE_OPENAI_DEPLOYMENT",
                  "value": "[parameters('openAiModelDeployment')]"
                },
                {
                  "name": "AZURE_OPENAI_API_KEY",
                  "secretRef": "openai-api-key"
                },
                {
                  "name": "AZURE_AI_SEARCH_ENDPOINT",
                  "value": "[format('https://{0}.search.windows.net', variables('searchName'))]"
                },
                {
                  "name": "AZURE_AI_SEARCH_KEY",
                  "secretRef": "search-admin-key"
                },
                {
                  "name": "AZURE_CONTENT_SAFETY_ENDPOINT",
                  "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('contentSafetyName')), '2023-05-01').endpoint]"
                },
                {
                  "name": "AZURE_CONTENT_SAFETY_KEY",
                  "secretRef": "content-safety-key"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "secretRef": "appinsights-connection-string"
                },
                {
                  "name": "GITHUB_TOKEN",
                  "secretRef": "github-token"
                },
                {
                  "name": "GITHUB_WEBHOOK_SECRET",
                  "secretRef": "github-webhook-secret"
                },
                {
                  "name": "KEY_VAULT_URL",
                  "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri]"
                },
                {
                  "name": "AZURE_CLIENT_ID",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', variables('orchestratorIdentityName')), '2023-01-31').clientId]"
                },
                {
                  "name": "GITHUB_REPO_OWNER",
                  "value": "[parameters('githubRepoOwner')]"
                },
                {
                  "name": "GITHUB_REPO_NAME",
                  "value": "[parameters('githubRepoName')]"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 10,
            "rules": [
              {
                "name": "http-scale",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "containerAppName": {
      "type": "string",
      "value": "[variables('containerAppName')]"
    },
    "orchestratorUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2023-05-01').configuration.ingress.fqdn)]"
    }
  }
}