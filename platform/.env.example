# ── Platform Configuration ──────────────────────────────────────────────────
# URL of the PRism orchestrator this platform will point users to.
# Can be the shared PRism instance or a self-hosted deployment.
PRISM_ORCHESTRATOR_URL=https://prism-dev-orchestrator.politerock-2dda79e7.eastus2.azurecontainerapps.io

# ── GitHub App (for automated workflow injection) ────────────────────────────
# Register a GitHub App at https://github.com/settings/apps/new
# Required permissions: Contents (write), Pull requests (write), Secrets (read)
GITHUB_APP_ID=
GITHUB_APP_SLUG=prism-gate
GITHUB_APP_PRIVATE_KEY_PATH=./github_app.pem
# OR use OAuth (simpler, requires manual PAT from user)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/api/setup/github/callback

# ── Azure AD App (for OAuth workspace picker) ────────────────────────────────
# Register an App at https://portal.azure.com → Azure Active Directory → App registrations
# Required API permission: Azure Service Management → user_impersonation (delegated)
# Redirect URI: http://localhost:8080/api/setup/azure/callback
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common
AZURE_AD_REDIRECT_URI=http://localhost:8080/api/setup/azure/callback

# ── Optional Platform Settings ───────────────────────────────────────────────
# Directory where workspace connection config is persisted
PLATFORM_CONFIG_PATH=/tmp/prism_workspace_config.json
# CORS origin for the frontend (if running on a different host)
PLATFORM_ORIGIN=
