# PRism Environment Variables Template
# ======================================
# Copy this file to .env and fill in your values
# This file should NOT be committed to version control

# ─────────────────────────────────────────────────────────────
# GitHub Configuration
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_REPO_OWNER=your-org-or-username
GITHUB_REPO_NAME=your-repository-name

# ─────────────────────────────────────────────────────────────
# Azure OpenAI
# ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_KEY=your_openai_key_here

# ─────────────────────────────────────────────────────────────
# Azure AI Search
# ─────────────────────────────────────────────────────────────
AZURE_AI_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_AI_SEARCH_KEY=your_search_key_here
AZURE_SEARCH_INDEX_NAME=incidents

# ─────────────────────────────────────────────────────────────
# Azure Content Safety
# ─────────────────────────────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-contentsafety.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your_content_safety_key_here

# ─────────────────────────────────────────────────────────────
# Azure Log Analytics (for Azure Functions)
# ─────────────────────────────────────────────────────────────
AZURE_LOG_WORKSPACE_ID=your_log_analytics_workspace_id_here
AZURE_LOG_WORKSPACE_KEY=your_log_analytics_key_here

# ─────────────────────────────────────────────────────────────
# Application Insights
# ─────────────────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://...

# ─────────────────────────────────────────────────────────────
# Azure Foundry Project (Optional)
# ─────────────────────────────────────────────────────────────
AZURE_FOUNDRY_PROJECT_CONNECTION_STRING=your_foundry_connection_string_here

# ─────────────────────────────────────────────────────────────
# Azure Key Vault (for production)
# ─────────────────────────────────────────────────────────────
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_CLIENT_ID=your_managed_identity_client_id

# ─────────────────────────────────────────────────────────────
# Local Development Settings
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
AZURE_INGEST_WINDOW_MINUTES=30

# ─────────────────────────────────────────────────────────────
# Deployment Settings (Optional - can be overridden via CLI)
# ─────────────────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=rg-prism-prod
AZURE_LOCATION=eastus2
PROJECT_NAME=prism
ENVIRONMENT=prod
