%%{init: {
  "flowchart": {
    "nodeSpacing": 55,
    "rankSpacing": 75,
    "diagramPadding": 25,
    "curve": "basis"
  }
}}%%

flowchart TD

    %% External Trigger
    GH[GitHub Pull Request]:::external

    %% MCP Layer
    subgraph MCP["MCP Integration Layer"]
        GMCP[GitHub MCP Server<br/>Diff · Commits · Coverage]:::mcp
        AMCP[Azure MCP Server<br/>Monitor Logs · Incidents]:::mcp
    end

    %% Orchestrator
    ORCH[Orchestrator Agent<br/>Microsoft Agent Framework]:::orchestrator

    %% Specialist Agents
    subgraph AGENTS["Specialist AI Agents (Parallel Execution)"]
        DA[Diff Analyst Agent<br/>Retries · Error Handling · Schema · Secrets]:::agent
        HA[History Agent<br/>File Changes ↔ Azure AI Search<br/>Semantic Incident Correlation]:::agent
        CA[Coverage Agent<br/>Test Regression Detection<br/>Copilot Trigger]:::agent
        TA[Timing Agent<br/>Deploy Window Risk Analysis]:::agent
    end

    %% Azure AI Search
    AIS[Azure AI Search<br/>Vectorization · Semantic Retrieval]:::azure

    %% Copilot
    COPILOT[GitHub Copilot Coding Agent<br/>Auto-Generates Missing Tests]:::copilot

    %% Data Contract
    CONTRACT[Agent Data Contract JSON<br/>agent_name · risk_modifier · status · findings · action]:::contract

    %% Verdict
    VA[Verdict Agent<br/>Deployment Confidence Score<br/>Risk Brief + Rollback Plan]:::verdict

    %% Governance
    subgraph FOUNDRY["Microsoft Foundry — Governance & Observability"]
        GOV[Audit Trail · Policy Guardrails · Token Tracking]:::foundry
        MON[Real-time Agent Monitoring]:::foundry
    end

    %% Output
    subgraph OUTPUT["Deployment Decision"]
        HIGH[Score ≥ 70<br/>Greenlight Deploy]:::pass
        LOW[Score < 70<br/>Deploy Blocked<br/>Test PR Auto-Opened]:::fail
    end

    VSCODE[VS Code Extension<br/>PRism Confidence Sidebar]:::vscode
    NEWPR[New Test PR on GitHub]:::external

    %% Flow
    GH -->|webhook| GMCP
    GH -->|webhook| AMCP

    GMCP --> ORCH
    AMCP --> ORCH

    ORCH --> DA
    ORCH --> HA
    ORCH --> CA
    ORCH --> TA

    HA -->|semantic query| AIS
    AMCP -->|incident data| AIS

    CA -->|coverage gap| COPILOT
    COPILOT -->|tests written| NEWPR
    NEWPR --> GH

    DA --> CONTRACT
    HA --> CONTRACT
    CA --> CONTRACT
    TA --> CONTRACT

    CONTRACT --> VA
    VA --> FOUNDRY

    FOUNDRY --> HIGH
    FOUNDRY --> LOW

    HIGH --> VSCODE
    LOW --> VSCODE

    %% Styles
    classDef external fill:#24292e,stroke:#000000,color:#ffffff,stroke-width:2px
    classDef mcp fill:#0078D4,stroke:#005A9E,color:#ffffff
    classDef orchestrator fill:#5C2D91,stroke:#3D1E63,color:#ffffff,font-weight:bold
    classDef agent fill:#106EBE,stroke:#005A9E,color:#ffffff
    classDef azure fill:#0078D4,stroke:#004578,color:#ffffff,stroke-dasharray:4
    classDef copilot fill:#2DA44E,stroke:#1A7F37,color:#ffffff
    classDef contract fill:#B45309,stroke:#92400E,color:#ffffff,stroke-dasharray:3
    classDef verdict fill:#8E562E,stroke:#6B4423,color:#ffffff,font-weight:bold
    classDef foundry fill:#3D1E63,stroke:#5C2D91,color:#ffffff
    classDef pass fill:#107C10,stroke:#0B5A0B,color:#ffffff
    classDef fail fill:#A4262C,stroke:#7F1D1D,color:#ffffff
    classDef vscode fill:#007ACC,stroke:#005F9E,color:#ffffff