%%{init: {
  "flowchart": {
    "nodeSpacing": 55,
    "rankSpacing": 75,
    "diagramPadding": 25,
    "curve": "basis"
  }
}}%%

flowchart TD

    %% External actors
    DEV[Developer\nFirst-time Setup]:::external
    GH[GitHub Pull Request]:::external
    GHA[GitHub Actions\nprism-gate.yml\nauto-installed by Setup Wizard]:::github
    COPILOT["🤖 GitHub Copilot Coding Agent\nAuto-Generates Missing Tests\nOpens Fix PR"]:::copilot
    NEWPR[New Test PR\nAuto-opened on GitHub]:::external
    VSCODE[VS Code Extension\nPRism Confidence Sidebar\nFreemium · 500 Runs for Judges]:::vscode

    %% Client environment
    CLIENT[Client Production Deployment\nAzure Log Analytics Workspace]:::external

    %% ═══════════════════════════════════════════════════════
    %% Azure Resource Group
    %% ═══════════════════════════════════════════════════════
    subgraph AZURE_RG["☁️ Azure Resource Group — rg-prism · Deployed via Bicep IaC"]

        %% ── Platform Container App ──
        subgraph ACA_PLAT["Azure Container App — Platform :8080"]
            PWZ[Setup Wizard\nGitHub OAuth · PAT · Workflow Install\nAzure AD OAuth · Workspace Connect]:::platform
        end

        %% ── Orchestrator Container App ──
        subgraph ACA_ORCH["Azure Container App — Orchestrator :8000"]
            ORCH["Orchestrator Agent\n⚡ Microsoft Agent Framework\nFastAPI · asyncio.gather"]:::orchestrator

            subgraph AGENTS["Specialist Agents — Parallel Execution via Agent Framework"]
                DA["Diff Analyst Agent\nSecrets · Schema Changes\nRetry Removal · Error Handling\n— Azure OpenAI enhanced —"]:::agent
                HA["History Agent\nFile ↔ Past Incidents\n— Azure AI Search via Azure MCP Server —"]:::agent
                CA["Coverage Agent\nTest Regression Detection\n— GitHub Copilot Auto-fix —"]:::agent
                TA["Timing Agent\nDeploy Window Risk\nFriday · After-hours · Holidays"]:::agent
            end

            CONTRACT[Agent Data Contract JSON\nagent_name · risk_score_modifier · status\nfindings · recommended_action]:::contract

            VA["Verdict Agent\nDeployment Confidence Score 0-100\nRisk Brief + Rollback Playbook\n— Azure OpenAI GPT-4o-mini —"]:::verdict

            subgraph FOUNDRY["🛡️ Microsoft Azure AI Foundry — Governance & Observability"]
                GOV["Audit Trail · Policy Guardrails\nazure-ai-projects SDK"]:::foundry
                MON["OpenTelemetry → Azure Monitor\nApplication Insights · Token Tracking"]:::foundry
            end

            subgraph OUTPUT["Deployment Decision"]
                HIGH[Score ≥ 70\n✅ Greenlight Deploy]:::pass
                LOW[Score < 70\n⛔ Deploy Blocked\n+ Test PR Auto-Opened]:::fail
            end
        end

        %% ── Ingestion Function App ──
        AFN["Azure Function App\nIncident Ingestion Pipeline\nTimer · Event Grid · HTTP"]:::azure

        %% ── Database ──
        DB[("Azure PostgreSQL Flexible Server\nRegistrations · Encrypted PATs")]:::azure

        %% ── MCP Integration Layer ──
        subgraph MCP["Azure MCP Server — Tool Connectivity"]
            AMCP["Azure MCP Server\nIncident Index Queries\nFile ↔ Incident Correlation"]:::mcp
        end

        %% ── Azure AI Services ──
        subgraph SERVICES["Azure AI Services"]
            AIS["Azure AI Search\nincidents-owner-repo index\nBM25 + Semantic Ranking"]:::azure
            AOI["Azure OpenAI — GPT-4o-mini\nSweden Central\nRisk Brief · Rollback Plan · File Extraction"]:::azure
            CS["Azure Content Safety\nLLM Output Guardrails"]:::azure
        end

    end

    %% === ONBOARDING FLOW ===
    DEV -->|GitHub OAuth + PAT| PWZ
    DEV -->|Azure AD OAuth| PWZ
    PWZ -->|store registration| DB
    PWZ -->|auto-commit prism-gate.yml| GH
    PWZ -->|link client workspace| CLIENT

    %% === INGESTION PIPELINE ===
    CLIENT -->|production logs\ncross-tenant query| AFN
    AFN -->|extract file paths\nfrom stack traces| AOI
    AFN -->|push incidents\nper-repo index| AIS

    %% === PR TRIGGER ===
    GH -->|PR opened/updated| GHA
    GHA -->|POST /analyze\nX-Client-ID| ORCH
    VSCODE -->|POST /analyze\nX-Client-ID| ORCH

    %% === ORCHESTRATOR INTERNAL FLOW ===
    ORCH -->|lookup RepoContext| DB
    ORCH --> DA
    ORCH --> HA
    ORCH --> CA
    ORCH --> TA

    HA -->|query via MCP| AMCP
    AMCP -->|semantic search\nby changed files| AIS

    CA -->|coverage gap trigger| COPILOT
    COPILOT -->|tests written| NEWPR
    NEWPR --> GH

    DA --> CONTRACT
    HA --> CONTRACT
    CA --> CONTRACT
    TA --> CONTRACT

    CONTRACT --> VA
    VA -->|generate risk brief\n+ rollback playbook| AOI
    VA -->|safety check| CS
    VA --> FOUNDRY

    FOUNDRY --> HIGH
    FOUNDRY --> LOW

    HIGH -->|PR comment\nmerge allowed| GH
    LOW -->|PR comment\nblock merge| GH

    HIGH --> VSCODE
    LOW --> VSCODE

    %% Styles
    classDef external fill:#24292e,stroke:#000000,color:#ffffff,stroke-width:2px
    classDef github fill:#24292e,stroke:#000000,color:#ffffff,stroke-width:2px
    classDef platform fill:#6B21A8,stroke:#4C1D95,color:#ffffff
    classDef mcp fill:#0078D4,stroke:#005A9E,color:#ffffff,stroke-width:3px
    classDef orchestrator fill:#5C2D91,stroke:#3D1E63,color:#ffffff,font-weight:bold,stroke-width:3px
    classDef agent fill:#106EBE,stroke:#005A9E,color:#ffffff
    classDef azure fill:#0078D4,stroke:#004578,color:#ffffff,stroke-width:2px
    classDef copilot fill:#2DA44E,stroke:#1A7F37,color:#ffffff,stroke-width:3px
    classDef contract fill:#B45309,stroke:#92400E,color:#ffffff,stroke-dasharray:3
    classDef verdict fill:#8E562E,stroke:#6B4423,color:#ffffff,font-weight:bold
    classDef foundry fill:#3D1E63,stroke:#5C2D91,color:#ffffff,stroke-width:3px
    classDef pass fill:#107C10,stroke:#0B5A0B,color:#ffffff
    classDef fail fill:#A4262C,stroke:#7F1D1D,color:#ffffff
    classDef vscode fill:#007ACC,stroke:#005F9E,color:#ffffff
