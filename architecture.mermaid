%%{init: {
  "flowchart": {
    "nodeSpacing": 55,
    "rankSpacing": 75,
    "diagramPadding": 25,
    "curve": "basis"
  }
}}%%

flowchart TD

    %% Onboarding
    DEV[Developer\nFirst-time Setup]:::external

    subgraph PLATFORM["PRism Setup Platform — :8080"]
        PWZ[Setup Wizard\nGitHub OAuth · PAT · Workflow Install\nAzure AD OAuth · Workspace Connect]:::platform
        DB[(PostgreSQL\nUsers · Registrations\nEncrypted PATs)]:::platform
    end

    %% External Trigger
    GH[GitHub Pull Request]:::external
    GHA[GitHub Actions\nprism-gate.yml\nauto-installed by Setup Wizard]:::external

    %% MCP Layer
    subgraph MCP["MCP Integration Layer"]
        GMCP[GitHub MCP Server\nDiff · Commits · Files]:::mcp
        AMCP[Azure MCP Server\nIncident Index Queries]:::mcp
    end

    %% Orchestrator
    ORCH[Orchestrator Agent\nMicrosoft Agent Framework\nFastAPI :8000]:::orchestrator

    %% Specialist Agents
    subgraph AGENTS["Specialist AI Agents — Parallel Execution (asyncio.gather)"]
        DA[Diff Analyst Agent\nSecrets · Schema Changes\nRetry Removal · Error Handling]:::agent
        HA[History Agent\nFile Changes ↔ Past Incidents\nAzure AI Search Correlation]:::agent
        CA[Coverage Agent\nTest Regression Detection\nCopilot Auto-fix Trigger]:::agent
        TA[Timing Agent\nDeploy Window Risk\nFriday · After-hours · Holidays]:::agent
    end

    %% Azure Services
    subgraph AZURE_SERVICES["Azure Services"]
        AIS[Azure AI Search\nincidents-owner-repo index\nBM25 + Semantic Retrieval]:::azure
        AFN[Azure Function App\nIncident Ingestion Pipeline\nTimer · Event Grid · HTTP]:::azure
        LAW[Azure Log Analytics\nProduction Incident Logs]:::azure
        AOI[Azure OpenAI GPT-4o-mini\nSweden Central\nRisk Brief + Rollback Plan]:::azure
        CS[Azure Content Safety\nLLM Output Guardrails]:::azure
        ACA[Azure Container Apps\nOrchestrator + Platform\nDeployed via Bicep IaC]:::azure
    end

    %% Copilot
    COPILOT[GitHub Copilot Coding Agent\nAuto-Generates Missing Tests\nOpens Fix PR]:::copilot

    %% Data Contract
    CONTRACT[Agent Data Contract JSON\nagent_name · risk_modifier · status\nfindings · recommended_action]:::contract

    %% Verdict
    VA[Verdict Agent\nDeployment Confidence Score 0-100\nRisk Brief + Rollback Playbook]:::verdict

    %% Governance
    subgraph FOUNDRY["Microsoft Foundry — Governance & Observability"]
        GOV[Audit Trail · Policy Guardrails\nAzure AI Projects Client]:::foundry
        MON[OpenTelemetry · Application Insights\nToken Tracking · Real-time Monitoring]:::foundry
    end

    %% Output
    subgraph OUTPUT["Deployment Decision"]
        HIGH[Score ≥ 70\n✅ Greenlight Deploy]:::pass
        LOW[Score < 70\n⛔ Deploy Blocked\n+ Test PR Auto-Opened]:::fail
    end

    VSCODE[VS Code Extension\nPRism Confidence Sidebar\nFreemium · 500 Runs for Judges]:::vscode
    NEWPR[New Test PR\nAuto-opened on GitHub]:::external

    %% === ONBOARDING FLOW ===
    DEV -->|GitHub OAuth + PAT| PWZ
    DEV -->|Azure AD OAuth| PWZ
    PWZ -->|store registration| DB
    PWZ -->|auto-commit prism-gate.yml| GH
    PWZ -->|link workspace| LAW

    %% === INCIDENT INGESTION PIPELINE ===
    LAW -->|production logs| AFN
    AFN -->|index incidents| AIS

    %% === PR ANALYSIS FLOW ===
    GH -->|PR opened/updated| GHA
    GHA -->|POST /analyze + X-Client-ID| ORCH
    GH -->|webhook| GMCP
    GMCP --> ORCH

    ORCH --> DA
    ORCH --> HA
    ORCH --> CA
    ORCH --> TA
    ORCH --> AMCP

    AMCP -->|per-repo incident data| AIS
    HA -->|semantic query| AIS

    CA -->|@copilot comment| COPILOT
    COPILOT -->|tests written| NEWPR
    NEWPR --> GH

    DA --> CONTRACT
    HA --> CONTRACT
    CA --> CONTRACT
    TA --> CONTRACT

    CONTRACT --> VA
    VA -->|GPT-4o-mini| AOI
    VA -->|safety check| CS
    CS --> VA
    VA --> FOUNDRY

    FOUNDRY --> HIGH
    FOUNDRY --> LOW

    HIGH -->|PR comment + merge allowed| GH
    LOW -->|PR comment + block merge| GH

    HIGH --> VSCODE
    LOW --> VSCODE

    %% Deployed on ACA
    ORCH -. deployed on .-> ACA
    PWZ -. deployed on .-> ACA

    %% Styles
    classDef external fill:#24292e,stroke:#000000,color:#ffffff,stroke-width:2px
    classDef platform fill:#6B21A8,stroke:#4C1D95,color:#ffffff
    classDef mcp fill:#0078D4,stroke:#005A9E,color:#ffffff
    classDef orchestrator fill:#5C2D91,stroke:#3D1E63,color:#ffffff,font-weight:bold
    classDef agent fill:#106EBE,stroke:#005A9E,color:#ffffff
    classDef azure fill:#0078D4,stroke:#004578,color:#ffffff,stroke-dasharray:4
    classDef copilot fill:#2DA44E,stroke:#1A7F37,color:#ffffff
    classDef contract fill:#B45309,stroke:#92400E,color:#ffffff,stroke-dasharray:3
    classDef verdict fill:#8E562E,stroke:#6B4423,color:#ffffff,font-weight:bold
    classDef foundry fill:#3D1E63,stroke:#5C2D91,color:#ffffff
    classDef pass fill:#107C10,stroke:#0B5A0B,color:#ffffff
    classDef fail fill:#A4262C,stroke:#7F1D1D,color:#ffffff
    classDef vscode fill:#007ACC,stroke:#005F9E,color:#ffffff
