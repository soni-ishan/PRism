# ── Azure OpenAI (GPT-4o-mini, Sweden Central) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# ── Azure AI Foundry ──
AZURE_FOUNDRY_PROJECT_CONNECTION_STRING=

# ── Azure Identity (Service Principal) ──
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── Azure Content Safety ──
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=

# ── Azure AI Search (History Agent) ──
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=

# ── Log Analytics (Incident Ingestion) ──
AZURE_LOG_WORKSPACE_ID=

# ── Application Insights (Tracing) ──
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Key Vault ──
KEY_VAULT_URL=

# ── Platform Configuration ──
PRISM_ORCHESTRATOR_URL=
DATABASE_URL=postgresql+asyncpg://prismadmin:<PASSWORD>@<PG-SERVER>.postgres.database.azure.com:5432/prism_platform?ssl=require

# ── GitHub OAuth ──
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# ── Azure AD OAuth ──
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_REDIRECT_URI=http://localhost:8080/api/setup/azure/callback

# ── Security ──
JWT_SECRET=
ENCRYPTION_KEY=

# ── Optional ──
PLATFORM_ORIGIN=
PLATFORM_CONFIG_PATH=/tmp/prism_workspace_config.json
